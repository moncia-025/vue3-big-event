  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueup/vue-quill": "^1.2.0",
    "axios": "^1.16.1",
    "element-plus": "^2.14.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "husky": "^8.0.0",
    "lint-staged": "^17.0.5",
